generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  USER
  ADMIN
}

enum ServiceType {
  SURFACE
  AIR
  EXPRESS
}


// User
model User {
  id String @id @default(cuid())

  name     String
  email    String @unique
  password String

  role UserRole @default(USER)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// Seller

model Seller {
  id String @id @default(cuid())

  sellerName  String
  companyName String

  email String?
  phone String?

  gstNumber String?

  address String?
  city    String?
  state   String?
  pincode String?

  isActive Boolean @default(true)

  shipments       Shipment[]
  sellerRateCards SellerRateCard[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

//Carrier

model Carrier {
  id String @id @default(cuid())

  name String @unique

  isActive Boolean @default(true)

  shipments Shipment[]
  rateCards RateCard[]

  rateCardTemplates RateCardTemplate[]
  sellerRateCards   SellerRateCard[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}


// Zones
model Zone {
  id String @id @default(cuid())

  name String @unique

  isActive Boolean @default(true)

  shipments Shipment[]
  rateCards RateCard[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// Shipment 

enum PaymentMode {
  PREPAID
  COD
}

enum ShipmentStatus {
  BOOKED
  PICKED_UP
  IN_TRANSIT
  DELIVERED
  RTO
  RTO_DELIVERED
  LOST
  DAMAGED
  CANCELLED
}

enum BillingStatus {
  PENDING
  BILLED
}

enum BillingEligibility {
  BILLABLE
  IGNORE
}

// Shipment

model Shipment {
  id String @id @default(cuid())

  awbNumber String @unique
  orderId   String

  customerName String?

  senderName    String?
  senderCity    String?
  senderState   String?
  senderPincode String?

  receiverName    String?
  receiverCity    String?
  receiverState   String?
  receiverPincode String?

  deadWeight       Float?
  volumetricWeight Float?

  shippingType String?

  paymentMethod String?

  totalAmount Float?
  codAmount   Float?

  orderId String?

  sellerId String
  seller Seller @relation(fields: [sellerId], references: [id])

  carrierId String
  carrier Carrier @relation(fields: [carrierId], references: [id])

  zoneId String
  zone Zone @relation(fields: [zoneId], references: [id])

  service ServiceType

  paymentMode PaymentMode

  billingEligibility BillingEligibility


  productValue Float

  actualWeight Float

  length Float?
  breadth Float?
  height Float?

  volumetricWeight Float

  applicableWeight Float

  pickupPincode String
  pickupCity String
  pickupState String

  deliveryPincode String
  deliveryCity String
  deliveryState String

  shipmentStatus ShipmentStatus

  billingStatus BillingStatus @default(PENDING)

  shipmentDate DateTime?

  billingMonth String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([sellerId])
  @@index([carrierId])
  @@index([zoneId])
  @@index([shipmentStatus])
  @@index([billingStatus])
  @@index([shipmentDate])
}


model MetroCity {
  id String @id @default(cuid())

  city String
  state String

  isActive Boolean @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([city, state])
}

model SpecialRegion {
  id String @id @default(cuid())

  state String
  city String?

  isActive Boolean @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([state, city])
}

