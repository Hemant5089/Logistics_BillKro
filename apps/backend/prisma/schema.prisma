model SellerRateCard {
  id   String  @id @default(cuid())
  name String?

  sellerId String
  seller   Seller @relation(fields: [sellerId], references: [id], onDelete: Cascade)

  masterRateCardId String?
  masterRateCard   RateCardTemplate? @relation(fields: [masterRateCardId], references: [id])

  carrierId String
  carrier   Carrier @relation(fields: [carrierId], references: [id])

  service ServiceType

  startWeight Float
  endWeight   Float

  maxWeight        Float
  additionalWeight Float

  localAmount           Float
  localAdditionalAmount Float

  stateAmount           Float
  stateAdditionalAmount Float

  roiAmount           Float
  roiAdditionalAmount Float

  metroAmount           Float
  metroAdditionalAmount Float

  specialAmount           Float
  specialAdditionalAmount Float

  isActive Boolean @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([sellerId])
  @@index([carrierId])
