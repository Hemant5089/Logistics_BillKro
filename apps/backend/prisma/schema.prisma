generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  USER
  ADMIN
}

enum ServiceType {
  SURFACE
  AIR
  EXPRESS
}

// User
model User {
  id String @id @default(cuid())

  name     String
  email    String @unique
  password String

  role UserRole @default(USER)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// Seller

model Seller {
  id String @id @default(cuid())

  sellerName  String
  companyName String

  email String?
  phone String?

  gstNumber String?

  address String?
  city    String?
  state   String?
  pincode String?

  isActive Boolean @default(true)

  shipments       Shipment[]
  sellerRateCards SellerRateCard[]
  billingRecords  BillingRecord[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

//Carrier

model Carrier {
  id String @id @default(cuid())

  name String @unique

  isActive Boolean @default(true)

  shipments      Shipment[]
  billingRecords BillingRecord[]

  rateCardTemplates RateCardTemplate[]
  sellerRateCards   SellerRateCard[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// Zones
model Zone {
  id String @id @default(cuid())

  name String @unique

  isActive Boolean @default(true)

  shipments      Shipment[]
  billingRecords BillingRecord[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// Shipment 

enum PaymentMode {
  PREPAID
  COD
}


// Need to implement previews enum here // 


enum ShipmentStatus {
  BOOKED
  PICKUP_AWAITED
  PICKED_UP
  SHIPPED
  IN_TRANSIT
  REACHED_AT_DESTINATION
  OUT_FOR_DELIVERY
  DELIVERED
  UNDELIVERED
  CANCELLED

  RTO_BOOKED
  RTO_IN_TRANSIT
  RTO_REACHED_DESTINATION
  RTO_OUT_FOR_DELIVERY
  RTO_DELIVERED

  LOST
  DAMAGED

  UNKNOWN
}


enum BillingStatus {
  PENDING
  BILLED
}

enum BillingEligibility {
  BILLABLE
  IGNORE
}

// Shipment

model Shipment {
  id String @id @default(cuid())

  awbNumber String @unique

  orderId String?

  customerName String?

  sellerId String
  seller   Seller @relation(fields: [sellerId], references: [id])

  carrierId String
  carrier   Carrier @relation(fields: [carrierId], references: [id])

  zoneId String
  zone   Zone   @relation(fields: [zoneId], references: [id])

  service ServiceType

  paymentMode PaymentMode

  billingEligibility BillingEligibility

  billingRecord BillingRecord?
  productValue  Float

  actualWeight Float

  length  Float?
  breadth Float?
  height  Float?

  volumetricWeight Float

  applicableWeight Float

  senderName    String
  senderPincode String
  senderCity    String
  senderState   String

  receiverName    String
  receiverPincode String
  receiverCity    String
  receiverState   String

  shipmentStatus ShipmentStatus

  billingStatus BillingStatus @default(PENDING)

  shipmentDate DateTime?

  billingMonth String?


  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([sellerId])
  @@index([carrierId])
  @@index([zoneId])
  @@index([shipmentStatus])
  @@index([billingStatus])
  @@index([shipmentDate])
}

model MetroCity {
  id String @id @default(cuid())

  city  String
  state String

  isActive Boolean @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([city, state])
}

model SpecialRegion {
  id String @id @default(cuid())

  state String
  city  String?

  isActive Boolean @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([state, city])
}

// Rate Card

model RateCardTemplate {
  id String @id @default(cuid())

  name String?

  carrierId String
  carrier   Carrier @relation(fields: [carrierId], references: [id])

  service ServiceType

  startWeight Float
  endWeight   Float

  maxWeight Float

  additionalWeight Float

  localAmount           Float
  localAdditionalAmount Float

  stateAmount           Float
  stateAdditionalAmount Float

  roiAmount           Float
  roiAdditionalAmount Float

  metroAmount           Float
  metroAdditionalAmount Float

  specialAmount           Float
  specialAdditionalAmount Float

  isActive Boolean @default(true)

  sellerRateCards SellerRateCard[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([carrierId])
}

model SellerRateCard {
  id   String  @id @default(cuid())
  name String?

  sellerId String
  seller   Seller @relation(fields: [sellerId], references: [id], onDelete: Cascade)

  masterRateCardId String?
  masterRateCard   RateCardTemplate? @relation(fields: [masterRateCardId], references: [id])

  carrierId String
  carrier   Carrier @relation(fields: [carrierId], references: [id])

  service        ServiceType
  billingRecords BillingRecord[]

  // COD Rules
  codThresholdAmount Float @default(2000)

  codFixedCharge Float @default(30)

  codPercentage Float @default(1.9)

  // RTO Rule
  rtoCharge Float @default(30)

  startWeight Float
  endWeight   Float

  maxWeight        Float
  additionalWeight Float

  localAmount           Float
  localAdditionalAmount Float

  stateAmount           Float
  stateAdditionalAmount Float
  roiAmount           Float
  roiAdditionalAmount Float

  metroAmount           Float
  metroAdditionalAmount Float

  specialAmount           Float
  specialAdditionalAmount Float

  isActive Boolean @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([sellerId])
  @@index([carrierId])
}

model BillingRecord {
  id String @id @default(cuid())

  shipmentId String   @unique
  shipment   Shipment @relation(fields: [shipmentId], references: [id])

  sellerId String
  seller   Seller @relation(fields: [sellerId], references: [id])

  carrierId String
  carrier   Carrier @relation(fields: [carrierId], references: [id])

  zoneId String
  zone   Zone   @relation(fields: [zoneId], references: [id])

  sellerRateCardId String
  sellerRateCard   SellerRateCard @relation(fields: [sellerRateCardId], references: [id])

  applicableWeight Float

  billedWeight Float

  slabStartWeight Float

  slabEndWeight Float

  forwardBaseCharge Float

  forwardAdditionalCharge Float

  forwardTotalCharge Float

  rtoCharge Float

  codCharge Float

  totalCharge Float

  billingMonth String

  createdAt DateTime @default(now())

  updatedAt DateTime @updatedAt

  @@index([sellerId])
  @@index([billingMonth])
}
